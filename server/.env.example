# Port to run the server on
PORT=5000

# MongoDB Connection URI (Local or Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/prioritymail_guardian

# Path to the Firebase service account JSON key file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Google Cloud OAuth 2.0 Credentials (for Gmail API integration)
GMAIL_CLIENT_ID=your_gmail_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# JWT or session secret
SESSION_SECRET=replace_with_a_long_random_secret
